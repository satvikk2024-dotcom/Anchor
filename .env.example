# ===== Anchor — Environment Variables =====
# Copy to .env and fill in real values. Never commit .env itself.

# ----- App -----
APP_ENV=development
LOG_LEVEL=INFO

# ----- Postgres -----
# Local native dev: postgresql://<your-mac-username>@localhost:5432/anchor
# Docker (later):   postgresql://anchor:anchor@localhost:5432/anchor
DATABASE_URL=postgresql://satvik@localhost:5432/anchor
POSTGRES_USER=anchor
POSTGRES_PASSWORD=anchor
POSTGRES_DB=anchor

# ----- n8n -----
N8N_HOST=localhost
N8N_PORT=5678
GENERIC_TIMEZONE=America/Los_Angeles

# ----- Ollama / LLM wrapper -----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
LLM_WRAPPER_PORT=8001
CACHE_LLM_CALLS=true
CACHE_DIR=./data/cache
