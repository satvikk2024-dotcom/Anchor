    {
      "parameters": {
        "jsCode": "const companyName = $json.company_name || '';\nconst jdUrl = $('Load Application').item.json.url;\n\nconst slug = companyName.toLowerCase().replace(/[^a-z0-9]/g, '');\nconst homepageUrl = `https://www.${slug}.com`;\nconst aboutUrl = `${homepageUrl}/about`;\n\n// Default careers guess off the homepage; override with the ATS's own\n// board root when the JD URL is from a known ATS \u2014 far more reliable\n// than guessing the marketing site's /careers path.\nlet careersUrl = `${homepageUrl}/careers`;\ntry {\n  const u = new URL(jdUrl);\n  const host = u.hostname.toLowerCase();\n  const parts = u.pathname.split('/').filter(Boolean);\n  if ((host === 'boards.greenhouse.io' || host === 'job-boards.greenhouse.io') && parts[0]) {\n    careersUrl = `https://${host}/${parts[0]}`;\n  } else if (host === 'jobs.lever.co' && parts[0]) {\n    careersUrl = `https://${host}/${parts[0]}`;\n  } else if (host.endsWith('.myworkdayjobs.com') && parts.length >= 2) {\n    careersUrl = `https://${host}/${parts[0]}/${parts[1]}`;\n  }\n} catch (e) {\n  // malformed JD URL \u2014 keep the homepage-based guess\n}\n\nreturn [{\n  json: {\n    ...$json,\n    domain: `${slug}.com`,\n    homepage_url: homepageUrl,\n    about_url: aboutUrl,\n    careers_url: careersUrl,\n  },\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1100,
        0
      ],
      "id": "a1c2e3f4-1111-4a11-8a11-111111111111",
      "name": "Derive Research URLs"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://news.google.com/rss/search?q={{ encodeURIComponent($json.company_name) }}&hl=en-US&gl=US&ceid=US:en",
        "options": {
          "response": {
            "response": {
              "responseFormat": "text"
            }
          }
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1320,
        -360
      ],
      "id": "77ba6995-eca0-4c4a-85c9-88153c0ad855",
      "name": "Fetch Company News",
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "mode": "xmlToJson",
        "dataPropertyName": "data",
        "options": {}
      },
      "type": "n8n-nodes-base.xml",
      "typeVersion": 1,
