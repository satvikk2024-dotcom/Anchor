        "operation": "executeQuery",
        "query": "INSERT INTO company (name, domain, synthesis, last_researched_at)\nVALUES ($1, $2, $3::jsonb, now())\nON CONFLICT (lower(name)) DO UPDATE SET\n  domain = EXCLUDED.domain,\n  synthesis = EXCLUDED.synthesis,\n  last_researched_at = now()\nRETURNING id, name",
        "options": {
          "queryReplacement": "={{ $json.company_name }},{{ $json.domain }},{{ $json.synthesis_json }}"
        }
