      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "jsCode": "const failed = !!$json.error || typeof $json.text !== 'string';\nreturn [{\n  json: {\n    homepage_text: failed ? '' : $json.text.slice(0, 3000),\n    homepage_ok: !failed,\n  },\n}];"
      },
