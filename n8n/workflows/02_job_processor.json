      "id": "b2c3d4e5-3131-4b31-8b31-313131313131",
      "name": "Persist JD Parse",
      "credentials": {
        "postgres": {
          "id": "IE4krf2WbUXsoRyf",
          "name": "Anchor Postgres"
        }
