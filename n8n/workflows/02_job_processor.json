      "id": "b8c9d0e1-8888-4b88-8b88-888888888888",
      "name": "Merge Research"
    },
    {
      "parameters": {
        "jsCode": "const research = $json;\nconst meta = $('Derive Research URLs').item.json;\n\nconst newsItems = research.news_items ?? [];\nconst newsLines = newsItems.length\n  ? newsItems.map((n) => `- ${n.title} (${n.source || 'unknown source'}, ${n.pub_date || 'no date'})`).join('\\n')\n  : '(no news items found)';\n\nconst sourcesAvailable = [];\nif (newsItems.length) sourcesAvailable.push('news');\nif (research.homepage_ok) sourcesAvailable.push('homepage');\nif (research.about_ok) sourcesAvailable.push('about');\nif (research.careers_ok) sourcesAvailable.push('careers');\n\nlet roleLine = `Role being hired for: ${meta.role_title}`;\nif (meta.team_or_org) roleLine += ` (team: ${meta.team_or_org})`;\n\nconst prompt = [\n  `Company: ${meta.company_name}`,\n  `Domain (best guess, may be wrong): ${meta.domain}`,\n  roleLine,\n  '',\n  '## Recent news headlines',\n  newsLines,\n  '',\n  '## Homepage text' + (research.homepage_ok ? '' : ' (unavailable)'),\n  research.homepage_ok ? research.homepage_text : '(fetch failed or domain guess incorrect)',\n  '',\n  '## About page text' + (research.about_ok ? '' : ' (unavailable)'),\n  research.about_ok ? research.about_text : '(fetch failed or page does not exist)',\n  '',\n  '## Careers page text' + (research.careers_ok ? '' : ' (unavailable)'),\n  research.careers_ok ? research.careers_text : '(fetch failed or page does not exist)',\n].join('\\n');\n\nreturn [{\n  json: {\n    prompt: prompt.slice(0, 12000),\n    sources_available: sourcesAvailable,\n    news_items: newsItems,\n  },\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2200,
