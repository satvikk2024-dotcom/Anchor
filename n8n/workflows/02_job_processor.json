        "operation": "executeQuery",
        "query": "INSERT INTO agent_run (application_id, workflow_name, agent_name, output_json)\nVALUES ($1::uuid, 'job_processor', 'jd_parser', $2::jsonb)\nRETURNING id",
        "options": {
          "queryReplacement": "={{ $json.application_id }},{{ $json.jd_json }}"
        }
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
