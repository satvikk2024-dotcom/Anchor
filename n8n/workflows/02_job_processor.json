    {
      "parameters": {
        "jsCode": "const synthesis = $json;\nconst meta = $('Derive Research URLs').item.json;\nconst prep = $('Prepare Synthesizer Input').item.json;\n\nreturn [{\n  json: {\n    company_name: meta.company_name,\n    domain: meta.domain,\n    role_title: meta.role_title,\n    application_id: $('Load Application').item.json.id,\n    synthesis_json: JSON.stringify({\n      ...synthesis,\n      raw_news: prep.news_items,\n      sources_available: prep.sources_available,\n    }),\n  },\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2860,
