      ],
      "id": "d4c6a397-a50b-4b8b-a241-a1bcb8953898",
      "name": "Parse News XML"
    },
    {
      "parameters": {
        "jsCode": "const channel = $input.item.json.rss?.channel ?? {};\nlet items = channel.item ?? [];\nif (!Array.isArray(items)) items = [items];\n\nconst news_items = items.slice(0, 5).map((i) => ({\n  title: i.title ?? null,\n  link: i.link ?? null,\n  pub_date: i.pubDate ?? null,\n  source: (i.source && typeof i.source === 'object') ? (i.source._ ?? null) : (i.source ?? null),\n}));\n\nreturn [{ json: { news_items } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1760,
        -360
      ],
      "id": "fb8c3776-f8d2-409c-9c54-bd5e9f4e320e",
      "name": "Extract News Items"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:8002/fetch",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ url: $json.homepage_url }) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1320,
        -120
      ],
      "id": "b2c3d4e5-2222-4b22-8b22-222222222222",
      "name": "Fetch Company Homepage",
      "onError": "continueRegularOutput",
